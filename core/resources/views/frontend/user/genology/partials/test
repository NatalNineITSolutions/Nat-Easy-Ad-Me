  <script>
  document.addEventListener('DOMContentLoaded', function() {
    // Auto-scaling based on tree depth
    function calculateTreeDepth(nodeElement) {
      let depth = 0;
      let current = nodeElement;
      
      while (current.querySelector('.child-node .tree-node')) {
        depth++;
        current = current.querySelector('.child-node .tree-node');
      }
      
      return depth;
    }
  
    const rootNode = document.querySelector('.tree-node.root');
    if (rootNode) {
      const depth = calculateTreeDepth(rootNode);
      const treeContainer = document.querySelector('.mlm-tree');
      const scaleClass = `tree-depth-${Math.min(depth, 5)}`;
      treeContainer.classList.add(scaleClass);
    }
  });
  </script>